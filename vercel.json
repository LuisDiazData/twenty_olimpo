{
  "buildCommand": "NODE_OPTIONS=--max-old-space-size=8192 npx nx build twenty-shared && NODE_OPTIONS=--max-old-space-size=8192 npx nx build twenty-front",
  "outputDirectory": "packages/twenty-front/build",
  "framework": null,
  "installCommand": "yarn install --frozen-lockfile",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
