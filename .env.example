# ============================================================
# .env.example — Plantilla de variables de entorno
# Copia este archivo como .env y llena los valores reales.
# Este archivo SÍ se commitea (sin valores reales).
# ============================================================

# ── Twenty CRM ──────────────────────────────────────────────
# URL del servidor de Twenty (cambiar en producción a la URL de Railway/Fly.io)
TWENTY_API_URL=http://localhost:3000
# API Key del workspace — generar en: Twenty CRM > Settings > API Keys
TWENTY_API_KEY=
# UUID del workspace member principal (Admin). Ver en Settings > Members.
TWENTY_WS_MEMBER_ID=

# ── Supabase ────────────────────────────────────────────────
# Obtener en: https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Anon key (uso público / frontend)
SUPABASE_KEY=
# Service role key (uso backend, acceso total — NO exponer en frontend)
# SUPABASE_SERVICE_ROLE_KEY=
# Conexión directa a PostgreSQL (obtener en: Settings > Database > Connection string)
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<id>.supabase.co:5432/postgres
# S3-compatible storage (obtener en: Settings > Storage > S3 Connection)
SUPABASE_S3_ENDPOINT=https://<id>.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY=
SUPABASE_S3_SECRET_KEY=
BUCKET_NAME=tramites-docs

# ── RunPod ──────────────────────────────────────────────────
# Obtener en: https://www.runpod.io/console/user/settings (API Keys)
RUNPOD_API_KEY=
# ID del endpoint serverless (visible en: RunPod > Serverless > tu endpoint)
RUNPOD_ENDPOINT_ID=

# ── LiteLLM / FastAPI attachment processor ──────────────────
# Misma key que RunPod (o usar OpenAI key si se cambia el modelo)
LLM_API_KEY=
# Formato: "runpod/<ENDPOINT_ID>" o "openai/gpt-4o" o "gemini/gemini-pro"
LITELLM_MODEL=runpod/<RUNPOD_ENDPOINT_ID>

# ── Helper Server (workflow-helpers.mjs) ────────────────────
# Puerto donde escucha el helper server (Twenty workflows lo llaman como host.docker.internal:4000)
HELPER_PORT=4000
# JSON con SLA en días hábiles por ramo y tipo de trámite.
# Formato: { "RAMO": { "default": N, "TIPO_TRAMITE": N } }
# Ramos: VIDA, GMM, AUTOS, PYME, DANOS
# Tipos: NUEVA_POLIZA, ENDOSO, RENOVACION, CANCELACION, SINIESTRO, COTIZACION_PYME
SLA_CONFIG={"VIDA":{"default":5,"SINIESTRO":3},"GMM":{"default":3,"SINIESTRO":2},"AUTOS":{"default":4,"SINIESTRO":2},"PYME":{"default":7,"SINIESTRO":3},"DANOS":{"default":5,"SINIESTRO":3}}

# ── n8n ─────────────────────────────────────────────────────
# URL de n8n (local en dev, URL pública en producción)
N8N_WEBHOOK_URL=http://localhost:5678

# ── Google OAuth / Gmail ────────────────────────────────────
# Obtener en: https://console.cloud.google.com > Credenciales > OAuth 2.0
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
# Cambiar dominio en producción: https://tu-dominio.com/auth/google/redirect
AUTH_GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/redirect
