      "parameters": {
        "jsCode": "const crypto = require('crypto');\nconst email = $('Gmail Trigger').first().json;\nconst headers_data = $('Extraer Headers Email').first().json;\nconst tramite_id = crypto.randomUUID();\nconst now = new Date();\nconst folio = `TRM-${now.getFullYear()}${String(now.getMonth()+1).padStart(2,'0')}${String(now.getDate()).padStart(2,'0')}-${tramite_id.substring(0,8).toUpperCase()}`;\nconst remitente = email.from?.value?.[0]?.address || (typeof email.from === 'string' ? email.from : '') || '';\nconst nombre_remitente = email.from?.value?.[0]?.name || remitente;\nconst asunto = email.subject || '';\nconst cuerpo = email.text || email.snippet || '';\nconst fecha = email.date || now.toISOString();\nconst message_id = headers_data._headers?.messageId || email.id || '';\nconst tiene_adjuntos = (email.attachments || []).length > 0;\nreturn [{ json: { tramite_id, folio, remitente, nombre_remitente, asunto, cuerpo, cuerpo_html: email.html || '', fecha, message_id, tiene_adjuntos } }];"
      },
