    {
      "parameters": {
        "jsCode": "const resp = $input.first().json; // fullResponse: { statusCode, body }\nconst gen = $('Generar UUID Trámite').first().json;\nconst status = resp.statusCode || 200;\nconst body = resp.body || resp;\nconst error_detectado = status >= 400 || !!body.detail || !!body.error;\nconst error_message = error_detectado ? (body.detail || body.error || `HTTP ${status}`) : null;\nreturn [{ json: {\n  tramite_id: gen.tramite_id, folio: gen.folio, remitente: gen.remitente,\n  nombre_remitente: gen.nombre_remitente, asunto: gen.asunto, cuerpo: gen.cuerpo,\n  fecha: gen.fecha, message_id: gen.message_id, tiene_adjuntos: gen.tiene_adjuntos,\n  error_detectado, error_message,\n  confianza_global: body.confianza_global || 0,\n  tipo_tramite: body.tipo_tramite || null, ramo: body.ramo || null,\n  numero_poliza: body.numero_poliza || null, nombre_asegurado: body.nombre_asegurado || null,\n  agente_cua: body.agente_cua || null, resumen: body.resumen || '',\n  es_duplicado_posible: body.es_duplicado_posible || false,\n  tramite_duplicado_ref: body.tramite_duplicado_ref || null\n}}];"
