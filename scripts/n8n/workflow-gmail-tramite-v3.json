        "jsCode": "const result = $input.first().json;\nconsole.log(`Reply procesado: record_id=${result.record_id}, note_added=${result.note_added}, twenty_id=${result.twenty_tramite_id}`);\nreturn [{ json: { ...result, accion: 'reply_procesado' } }];"
