    {
      "parameters": {
        "jsCode": "// Extraer Message-ID e In-Reply-To de los headers del email\n// n8n Gmail Trigger (mailparser) expone messageId e inReplyTo directamente\nconst email = $input.first().json;\n\nconst rawMessageId = email.messageId || (email.headers && (email.headers['message-id'] || email.headers['Message-ID'])) || email.id || '';\nconst rawInReplyTo = email.inReplyTo || (email.headers && (email.headers['in-reply-to'] || email.headers['In-Reply-To'])) || '';\n\n// Limpiar angle brackets: <abc@mail.com> → abc@mail.com\nconst cleanId = (id) => (id || '').replace(/[<>\\s]/g, '');\n\nconst messageId = cleanId(rawMessageId) || (email.id || '');\nconst inReplyTo = cleanId(rawInReplyTo);\n\nreturn [{\n  json: {\n    ...email,\n    _headers: {\n      messageId,\n      inReplyTo,\n      isReply: !!inReplyTo\n    }\n  }\n}];"
      },
      "id": "extract-headers",
      "name": "Extraer Headers Email",
      "type": "n8n-nodes-base.code",
