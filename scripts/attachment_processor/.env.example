# ── attachment-processor — variables requeridas ──────────────────────────────
# Copia este archivo como .env en la raíz del monorepo y llena los valores.
# El servicio carga automáticamente desde: <raíz>/.env

# Twenty CRM
TWENTY_API_URL=http://localhost:3000
TWENTY_API_KEY=

# Supabase
SUPABASE_URL=https://<proyecto>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
BUCKET_NAME=tramites-docs

# LLM / AI (requerido)
LITELLM_MODEL=openai/gpt-4o
LLM_MODEL=openai/gpt-4o
LLM_API_KEY=
OPENAI_API_KEY=

# RunPod — requerido solo si usas OCR pesado
RUNPOD_ENDPOINT_ID=
RUNPOD_API_KEY=

# Seguridad interna (para autenticar llamadas n8n → FastAPI)
INTERNAL_API_KEY=
